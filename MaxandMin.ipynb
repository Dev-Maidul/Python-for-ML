   "source": [
    "### Codeforces problem K. Max and Min"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "e7c44482",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "-5 20\n"
     ]
    }
   ],
   "source": [
    "inp=input();\n",
    "numbers=inp.split();\n",
    "a=int(numbers[0]);\n",
    "b=int(numbers[1]);\n",
    "c=int(numbers[2]);\n",
    "min=a;\n",
    "max=a;\n",
    "if(b<min):\n",
    "    min=b;\n",
    "if(c<min):\n",
    "    min=c;\n",
    "\n",
    "if(b>max):\n",
    "    max=b;\n",
    "if(c>max):\n",
    "    max=c;\n",
    "print(min,max)"
   ]
  },
