   "source": [
    "n=int(input())\n",
    "target=float(input())\n",
    "total=0\n",
    "for _ in range(n):\n",
    "    loss=float(input())\n",
    "    total+=loss\n",
    "\n",
    "avg = total / n\n",
    "\n",
    "if avg <= target:\n",
    "    print(\"PASS\")\n",
    "else:\n",
    "    print(\"RETRY\")"
   ]
  },
