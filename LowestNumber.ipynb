   "source": [
    "n = int(input())\n",
    "arr = list(map(int, input().split()))\n",
    "\n",
    "min_value = arr[0]\n",
    "position = 1\n",
    "\n",
    "for i in range(n):\n",
    "    if arr[i] < min_value:\n",
    "        min_value = arr[i]\n",
    "        position = i + 1\n",
    "\n",
    "print(min_value, position)"
   ]
