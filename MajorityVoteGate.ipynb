   "source": [
    "n=int(input())\n",
    "yes=0;\n",
    "no=0;\n",
    "for _ in range(n):\n",
    "    vote=input()\n",
    "    if(vote==\"YES\"):\n",
    "        yes=yes+1\n",
    "    elif(vote==\"NO\"):\n",
    "        no=no+1\n",
    "if(yes>=no):\n",
    "    print(\"ACCEPT\")\n",
    "else:\n",
    "    print(\"REJECT\")\n",
    "        "
   ]
